{
  "name": "Incognito History Tracker",
  "version": "2.0.0",
  "manifest_version": 3,
  "description": "Tracks browsing history across all modes including Incognito. Data stays local — export to JSON for use with the Brave History Access C tool.",
  "permissions": [
    "storage",
    "tabs",
    "activeTab",
    "downloads"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "incognito": "spanning",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
